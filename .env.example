# NexusAI Environment Configuration
# Copy to .env and fill in your values. Never commit .env to git.

DATABASE_URL=postgresql+asyncpg://user:password@host/neondb?sslmode=require
JWT_SECRET_KEY=change_this_to_a_long_random_secret_key_32chars
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

ADMIN_EMAIL=admin@nexusai.com
ADMIN_PASSWORD=SecureAdminTest2026!
MANAGER_EMAIL=manager@nexusai.com
MANAGER_PASSWORD=manager123
GUEST_EMAIL=guest@nexusai.com
GUEST_PASSWORD=guestpassword

REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=300

MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15
LOW_STOCK_THRESHOLD=15
SEED_PRODUCT_COUNT=100
PRODUCTS_PER_PAGE=12

# TechSimPlus GenAI (Google Gemini, Groq, Ollama)
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-8b-8192
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3


# Real SMTP (optional — logs to console if unset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=noreply@nexusai.com
SMTP_USE_TLS=true
APP_BASE_URL=http://127.0.0.1:8000

DEBUG=false
